# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/newchat?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username

# Auth
JWT_SECRET=your-jwt-secret-here

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=newchat-uploads
R2_PUBLIC_URL=https://your-account-id.r2.com/

# Web Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=BGKdWrQ4GtEjw3tIyVU2jdhtDeee3E-co6-FPQ3dtHQ8Wr18tVb_NUgfnbQlUs011o4JyFiuqwYe606vzU_HOpY
VAPID_PRIVATE_KEY=i6NPjrR1tQot59zEKFuApEREOnYPYIwj07jyx1iMbF8

